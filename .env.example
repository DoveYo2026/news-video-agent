# News API Configuration
NEWS_API_KEY=your_newsapi_key_here
NEWS_API_URL=https://newsapi.org/v2

# Google Cloud TTS Configuration
GOOGLE_APPLICATION_CREDENTIALS=path/to/google-credentials.json
TTS_LANGUAGE_CODE=en-GB
TTS_VOICE_GENDER=FEMALE

# TikTok Upload Configuration
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
TIKTOK_REFRESH_TOKEN=your_tiktok_refresh_token

# WeChat Configuration
WECHAT_ACCESS_TOKEN=your_wechat_access_token
WECHAT_MEDIA_ID=your_wechat_media_id

# Video Generation Settings
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
VIDEO_DURATION_MIN=15
VIDEO_DURATION_MAX=30
VIDEO_BITRATE=5000k

# Output Configuration
OUTPUT_DIR=./output/videos
TEMP_DIR=./temp
LOG_LEVEL=INFO

# Scheduling
SCHEDULE_TIME=09:00
VIDEOS_PER_DAY=3
